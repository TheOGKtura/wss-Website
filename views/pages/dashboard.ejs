<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link rel="stylesheet" href="css/app-shell.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="css/dashboard.css"
</head>
<body class="with-sidebar">
  <aside class="app-sidebar">
    <div class="meta">
      <p class="brand">WSS Thesis</p>
      <p class="title">Realtime Production</p>
    </div>

    <%- include("../partials/myView") %>

  </aside>

  <main class="shell">
    <section class="card card-hero">
      <div class="header">
        <div>
          <p class="eyebrow">Production Command Center</p>
          <h1>Realtime line performance and forecast intelligence</h1>
          <p class="sub">Live metrics from operations and lines, refreshed automatically when changes arrive.</p>
        </div>
        <div style="display:flex; gap:8px;">
          <span class="badge badge-success">Realtime Active</span>
          <span class="badge badge-neutral">Weighted MA</span>
        </div>
      </div>
    </section>
    <!-- SAMPLE DATA -->
    <section class="metrics">
      <article class="metric-card"><p class="metric-label">Today Ops</p><p id="metric-today-operations" class="metric-value">24</p></article>
      <article class="metric-card"><p class="metric-label">Total Ops (Loaded)</p><p id="metric-total-operations" class="metric-value">161</p></article>
      <article class="metric-card"><p class="metric-label">Quality Rate</p><p id="metric-quality-rate" class="metric-value">88.2%</p></article>
      <article class="metric-card"><p class="metric-label">Quota Completion</p><p id="metric-quota-completion" class="metric-value">76.5%</p></article>
      <article class="metric-card"><p class="metric-label">Active Lines</p><p id="metric-active-lines" class="metric-value">40</p></article>
    </section>
    
    <section class="two-cols">
      <article class="card">
        <div class="card-head">
          <div>
            <h3>Weekly Throughput</h3>
            <p class="sub">Last 7 days of operation events</p>
          </div>
          <span class="badge badge-brand">Live</span>
        </div>
        <div id="weeklyChart" class="chart">
          <div class="chart-grid"></div>
          <svg id="weekly-svg" class="line-svg" viewBox="0 0 600 240" preserveAspectRatio="none"></svg>
        </div>
      </article>

      <article class="card">
        <div class="card-head">
          <div>
            <h3>Forecast Projection</h3>
            <p class="sub">4-week weighted moving average</p>
          </div>
          <span class="badge badge-neutral">Predictive</span>
        </div>
        <div id="forecastChart" class="chart">
          <div class="chart-grid"></div>
          <div id="forecast-bars" class="bars"></div>
        </div>
      </article>
    </section>

    <section id="dashboard-warnings" class="card warnings">
      <h3>Data Warnings</h3>
      <ul id="dashboard-warnings-list">
        <li>Realtime subscription is running in demo mode on this static page.</li>
        <li>Connect to backend APIs to replace sample metrics.</li>
      </ul>
    </section>

    <section class="three-cols">
      <article class="card">
        <div class="card-head">
          <div>
            <h3>Product Stream</h3>
            <p class="sub">Latest operation records</p>
          </div>
          <a href="records.html" class="link">View all</a>
        </div>

        <div class="table-shell">
          <table>
            <thead>
              <tr>
                <th>Product Name</th>
                <th>Weight</th>
                <th>Defects</th>
                <th>Operator</th>
                <th>Time</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="dashboard-product-tbody"></tbody>
          </table>
        </div>

        <div class="table-footer">
          <span id="product-page-info">Page 1</span>
          <div class="pager">
            <button type="button" id="product-prev">Previous</button>
            <button type="button" id="product-next">Next</button>
          </div>
        </div>
      </article>

      <article class="card">
        <div class="card-head">
          <div>
            <h3>Quota Monitor</h3>
            <p class="sub">Per-line completion status</p>
          </div>
          <span class="badge badge-neutral">Shift</span>
        </div>

        <div class="table-shell">
          <table>
            <thead>
              <tr>
                <th>Line</th>
                <th>Shift</th>
                <th>RQ</th>
                <th>AQ</th>
                <th>Done</th>
              </tr>
            </thead>
            <tbody id="dashboard-quota-tbody"></tbody>
          </table>
        </div>

        <div class="table-footer">
          <span id="quota-page-info">Page 1</span>
          <div class="pager">
            <button type="button" id="quota-prev">Previous</button>
            <button type="button" id="quota-next">Next</button>
          </div>
        </div>
      </article>
    </section>
  </main>

  <script>
    const dashboardData = {
      weekly: { labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'], data: [14, 18, 16, 22, 24, 20, 19] },
      forecast: { labels: ['Wk 13', 'Wk 14', 'Wk 15', 'Wk 16'], data: [20, 22, 24, 23] },
      products: [
        { product_name: 'CDO CRISPY BURGER 228g', weight_reading: 227.65, defect_weight: false, defect_packaging: false, operator_name: 'L. Cruz', timestamp: '2026-03-24 08:05', rejected: false },
        { product_name: 'CDO CRISPY BURGER 228g', weight_reading: 228.35, defect_weight: false, defect_packaging: false, operator_name: 'A. Santos', timestamp: '2026-03-24 08:10', rejected: false },
        { product_name: 'CDO CRISPY BURGER 228g', weight_reading: 229.05, defect_weight: true, defect_packaging: false, operator_name: 'M. Dela', timestamp: '2026-03-24 08:15', rejected: true },
        { product_name: 'CDO CRISPY BURGER 228g', weight_reading: 227.30, defect_weight: false, defect_packaging: false, operator_name: 'L. Cruz', timestamp: '2026-03-24 08:20', rejected: false }
      ],
      quota: [
        { line: 'Line 1', shift: 'A', rq: 120, aq: 120, done: true },
        { line: 'Line 2', shift: 'B', rq: 120, aq: 115, done: false },
        { line: 'Line 3', shift: 'A', rq: 120, aq: 120, done: true },
        { line: 'Line 4', shift: 'B', rq: 120, aq: 118, done: false }
      ]
    };

    function drawWeeklyLineChart() {
      const svg = document.getElementById('weekly-svg');
      const values = dashboardData.weekly.data;
      const max = Math.max(...values, 1);
      const width = 600;
      const height = 240;
      const padX = 30;
      const padY = 20;
      const stepX = (width - padX * 2) / (values.length - 1);

      const points = values.map((v, i) => {
        const x = padX + i * stepX;
        const y = height - padY - ((v / max) * (height - padY * 2));
        return `${x},${y}`;
      }).join(' ');

      const pathPoints = values.map((v, i) => {
        const x = padX + i * stepX;
        const y = height - padY - ((v / max) * (height - padY * 2));
        return `${i === 0 ? 'M' : 'L'} ${x} ${y}`;
      }).join(' ');

      svg.innerHTML = `
        <polyline fill="rgba(239, 68, 68, 0.12)" stroke="none" points="${points} ${width - padX},${height - padY} ${padX},${height - padY}" />
        <path d="${pathPoints}" fill="none" stroke="#ef4444" stroke-width="4" stroke-linejoin="round" stroke-linecap="round"></path>
        ${values.map((v, i) => {
          const x = padX + i * stepX;
          const y = height - padY - ((v / max) * (height - padY * 2));
          return `<circle cx="${x}" cy="${y}" r="4" fill="#fca5a5"/>`;
        }).join('')}
      `;
    }

    function drawForecastBars() {
      const container = document.getElementById('forecast-bars');
      const values = dashboardData.forecast.data;
      const labels = dashboardData.forecast.labels;
      const max = Math.max(...values, 1);

      container.innerHTML = values.map((value, i) => {
        const h = Math.max(8, Math.round((value / max) * 190));
        return `
          <div class="bar-wrap">
            <div class="bar" style="height:${h}px" title="${value}"></div>
            <div class="bar-label">${labels[i]}</div>
          </div>
        `;
      }).join('');
    }

    function renderProductTable() {
      const tbody = document.getElementById('dashboard-product-tbody');
      tbody.innerHTML = dashboardData.products.map((row) => {
        const defectText = `${row.defect_weight ? 'W' : '-'} / ${row.defect_packaging ? 'P' : '-'}`;
        const status = row.rejected ? '<span class="status-bad">Rejected</span>' : '<span class="status-ok">Accepted</span>';
        return `
          <tr>
            <td>${row.product_name}</td>
            <td>${row.weight_reading}</td>
            <td>${defectText}</td>
            <td>${row.operator_name}</td>
            <td>${row.timestamp}</td>
            <td>${status}</td>
          </tr>
        `;
      }).join('');
    }

    function renderQuotaTable() {
      const tbody = document.getElementById('dashboard-quota-tbody');
      tbody.innerHTML = dashboardData.quota.map((row) => {
        return `
          <tr>
            <td>${row.line}</td>
            <td>${row.shift}</td>
            <td>${row.rq}</td>
            <td>${row.aq}</td>
            <td>${row.done ? '<span class="status-ok">Yes</span>' : '<span class="status-bad">No</span>'}</td>
          </tr>
        `;
      }).join('');
    }

    drawWeeklyLineChart();
    drawForecastBars();
    renderProductTable();
    renderQuotaTable();
  </script>
</body>
</html>
