<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users Module</title>
  <link rel="stylesheet" href="css/app-shell.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="css/settings.css">
</head>
<body class="with-sidebar">
  <aside class="app-sidebar">
    <div class="meta">
      <p class="brand">WSS Thesis</p>
      <p class="title">Realtime Production</p>
    </div>

    <%- include("../partials/myView") %>

  </aside>
  <!-- SAMPLE DATA -->
  <main class="container">
    <section class="card">
      <div class="header">
        <div>
          <p class="eyebrow">Administration</p>
          <h1>Users Module</h1>
          <p class="sub">Manage users with modal-based create, update, and delete actions.</p>
        </div>
        <button type="button" id="open-user-create" class="btn btn-primary">Add User</button>
      </div>
    </section>

    <section class="notice hidden" id="notice-box">User created successfully.</section>
    <section class="error hidden" id="error-box">Unable to load users.</section>

    <section class="card" style="margin-top: 16px;">
      <div class="header" style="align-items: center;">
        <h2 style="margin:0; font-size: 22px;">Users List</h2>
        <span class="badge">Page 1</span>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Username</th>
              <th>Email</th>
              <th>Role</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="settings-users-tbody">
            <tr>
              <td>admin</td>
              <td>admin@example.com</td>
              <td><span class="badge badge-brand">admin</span></td>
              <td>Mar 13, 2026 10:10 AM</td>
              <td>
                <div class="actions">
                  <button
                    type="button"
                    class="open-user-edit btn-ghost"
                    data-id="1"
                    data-authid="auth-uuid-1"
                    data-username="admin"
                    data-email="admin@example.com"
                    data-role="admin"
                  >Edit</button>
                  <button type="button" class="btn-danger">Delete</button>
                </div>
              </td>
            </tr>
            <tr>
              <td>operator1</td>
              <td>operator1@example.com</td>
              <td><span class="badge">operator</span></td>
              <td>Mar 12, 2026 08:22 AM</td>
              <td>
                <div class="actions">
                  <button
                    type="button"
                    class="open-user-edit btn-ghost"
                    data-id="2"
                    data-authid="auth-uuid-2"
                    data-username="operator1"
                    data-email="operator1@example.com"
                    data-role="operator"
                  >Edit</button>
                  <button type="button" class="btn-danger">Delete</button>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="footer">
        <span>Rows per page: 12</span>
        <div class="pager">
          <button disabled>Previous</button>
          <button>Next</button>
        </div>
      </div>
    </section>
  </main>

  <div id="user-modal" class="modal-overlay">
    <div class="modal">
      <div class="modal-head">
        <h2 id="user-modal-title">Add User</h2>
        <button type="button" id="close-user-modal" class="close">Close</button>
      </div>

      <form id="user-modal-form" class="form-grid" onsubmit="event.preventDefault();">
        <input type="hidden" id="user-action" value="create">
        <input type="hidden" id="user-id" value="">
        <input type="hidden" id="user-authid" value="">

        <label>
          <span class="label">Username</span>
          <input id="user-username" required>
        </label>

        <label>
          <span class="label">Email</span>
          <input id="user-email" type="email" required>
        </label>

        <label>
          <span class="label" id="password-label">Password</span>
          <input id="user-password" type="password">
          <p class="hint">Minimum 8 characters.</p>
        </label>

        <label>
          <span class="label">Role</span>
          <select id="user-role">
            <option value="operator">operator</option>
            <option value="manager">manager</option>
            <option value="admin">admin</option>
          </select>
        </label>

        <div class="form-actions">
          <button type="button" id="cancel-user-modal" class="btn-ghost">Cancel</button>
          <button type="submit" id="submit-user-modal" class="btn btn-primary">Create User</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    (() => {
      const modal = document.getElementById('user-modal');
      const openCreate = document.getElementById('open-user-create');
      const closeBtn = document.getElementById('close-user-modal');
      const cancelBtn = document.getElementById('cancel-user-modal');
      const title = document.getElementById('user-modal-title');
      const submit = document.getElementById('submit-user-modal');
      const action = document.getElementById('user-action');
      const id = document.getElementById('user-id');
      const authid = document.getElementById('user-authid');
      const username = document.getElementById('user-username');
      const email = document.getElementById('user-email');
      const password = document.getElementById('user-password');
      const role = document.getElementById('user-role');
      const passwordLabel = document.getElementById('password-label');

      const openModal = () => {
        modal.style.display = 'flex';
      };

      const closeModal = () => {
        modal.style.display = 'none';
      };

      const setCreateMode = () => {
        title.textContent = 'Add User';
        submit.textContent = 'Create User';
        action.value = 'create';
        id.value = '';
        authid.value = '';
        username.value = '';
        email.value = '';
        password.value = '';
        password.required = true;
        passwordLabel.textContent = 'Password';
        role.value = 'operator';
      };

      const setEditMode = (button) => {
        title.textContent = 'Edit User';
        submit.textContent = 'Save Changes';
        action.value = 'update';
        id.value = button.dataset.id || '';
        authid.value = button.dataset.authid || '';
        username.value = button.dataset.username || '';
        email.value = button.dataset.email || '';
        password.value = '';
        password.required = false;
        passwordLabel.textContent = 'Password (leave blank to keep current)';
        role.value = button.dataset.role || 'operator';
      };

      openCreate?.addEventListener('click', () => {
        setCreateMode();
        openModal();
      });

      closeBtn?.addEventListener('click', closeModal);
      cancelBtn?.addEventListener('click', closeModal);

      modal?.addEventListener('click', (event) => {
        if (event.target === modal) {
          closeModal();
        }
      });

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element) || !target.classList.contains('open-user-edit')) {
          return;
        }

        setEditMode(target);
        openModal();
      });
    })();
  </script>
</body>
</html>
