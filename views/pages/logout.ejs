<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logging Out</title>
  <meta http-equiv="refresh" content="1;url=index.html">
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(160deg, #050a20, #0b1436 55%, #111827);
      color: #e5e7eb;
    }

    .card {
      width: min(420px, 92vw);
      padding: 24px;
      border: 1px solid #334155;
      border-radius: 14px;
      background: rgba(15, 23, 42, 0.85);
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
      text-align: center;
    }

    h1 {
      margin: 0 0 10px;
      font-size: 1.25rem;
      color: #f8fafc;
    }

    p {
      margin: 0;
      color: #cbd5e1;
      font-size: 0.95rem;
      line-height: 1.4;
    }

    a {
      color: #93c5fd;
    }
  </style>
</head>
<body>
  <main class="card">
    <h1>Logging out...</h1>
    <p>You will be redirected to the login page shortly.</p>
    <p><a href="index.html">Go now</a></p>
  </main>

  <script>
    try {
      localStorage.removeItem('supabase.auth.token');
      sessionStorage.clear();
    } catch (_e) {
      // Ignore storage access issues.
    }

    setTimeout(function () {
      window.location.href = 'index.html';
    }, 700);
  </script>
</body>
</html>
