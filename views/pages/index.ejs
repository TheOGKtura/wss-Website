<!doctype html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>WSS Login</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="css/index.css" rel="stylesheet">

  <!-- Light/Dark Mode Toggle-->
  <script>
    (() => {
      const stored = localStorage.getItem('theme');
      const isDark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.classList.toggle('dark', isDark);
    })();
  </script>

</head> 
<body>
  <main class="main">
    <div class="bg-blur"></div>

    <section class="card">
      <p class="eyebrow">WSS Thesis</p>
      <h1>Realtime Production Login</h1>
      <p class="subtitle">Sign in with your account.</p>

      <div id="notice" class="alert notice hidden">Your session expired. Please sign in again.</div>
      <div id="error" class="alert error hidden">Login failed.</div>

      <form class="form" action="\" method="post" onsubmit="event.preventDefault(); sendPOSTRequest(); resetForm(); ">
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required>
        </div>

        <div class="field">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" required>
        </div>

        <input type="submit" class="submit" value="Sign in"/>
      </form>

      <div class="helper-row">
        <span></span>
        <button type="button" id="toggleTheme" class="theme-btn">Toggle theme</button>
      </div>
    </section>

    <script src="js/auth.js"></script>
  </main>
 
